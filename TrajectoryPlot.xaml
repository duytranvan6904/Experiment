<UserControl x:Class="Microsoft.Samples.Kinect.BodyBasics.TrajectoryPlot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150" HorizontalAlignment="Stretch">
    <Grid Background="#1e1e2e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Name="lblTitle" Text="Title" Foreground="#cdd6f4" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
        
        <Canvas Name="plotCanvas" Grid.Row="1" Margin="30,5,5,20">
            <!-- Grid lines -->
            <Line X1="0" Y1="0" X2="0" Y2="100" Stroke="#45475a" StrokeThickness="1" Name="yAxis"/>
            <Line X1="0" Y1="100" X2="260" Y2="100" Stroke="#45475a" StrokeThickness="1" Name="xAxis"/>
            
            <Polyline Name="polyMeasured" Stroke="#a6e3a1" StrokeThickness="1.5" />
            <Polyline Name="polyPredicted" Stroke="#f38ba8" StrokeThickness="1.5" StrokeDashArray="2,1" />
        </Canvas>
        
        <!-- Y-axis labels (min/max) -->
        <TextBlock Name="lblMax" Text="1.0" Foreground="#6c7086" FontSize="8" VerticalAlignment="Top" HorizontalAlignment="Left" Grid.Row="1" Margin="2,5,0,0"/>
        <TextBlock Name="lblMin" Text="0.0" Foreground="#6c7086" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Grid.Row="1" Margin="2,0,0,20"/>
    </Grid>
</UserControl>
