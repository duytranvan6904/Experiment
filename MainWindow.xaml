<Window x:Class="Microsoft.Samples.Kinect.BodyBasics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Microsoft.Samples.Kinect.BodyBasics"
        Title="Body Basics" 
        Height="720" Width="1200" 
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"> 
  <Window.Resources>
    <SolidColorBrush x:Key="MediumGreyBrush" Color="#ff6e6e6e" />
    <SolidColorBrush x:Key="KinectPurpleBrush" Color="#ff52318f" />
    <SolidColorBrush x:Key="KinectBlueBrush" Color="#ff00BCF2" />
  </Window.Resources>
  <Grid Margin="10 0 10 0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Image Grid.Row="0" Source="Images\Logo.png" HorizontalAlignment="Left" Stretch="Fill" Height="32" Width="81" Margin="0 10 0 5" />
    <TextBlock Grid.Row="0" Margin="0 0 -1 0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{StaticResource MediumGreyBrush}" FontFamily="Segoe UI" FontSize="18">Body Basics</TextBlock>
    <Image Grid.Row="0" Source="Images\Status.png" Stretch="None" HorizontalAlignment="Center" Margin="0 0 0 5" />

    <!-- Main content: image view on the left and control panel on the right -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="320" /> <!-- New Dashboard Column -->
      </Grid.ColumnDefinitions>

      <Viewbox Grid.Column="0" HorizontalAlignment="Center">
        <Image Source="{Binding ImageSource}" Stretch="UniformToFill" />
      </Viewbox>

      <!-- Existing Experiment Controls -->
      <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Top">
        <TextBlock FontSize="16" FontWeight="Bold" Margin="0,0,0,8">Experiment Controls</TextBlock>
        
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
          <TextBlock VerticalAlignment="Center" Margin="0,0,6,0">ROS IP:</TextBlock>
          <TextBox Name="txtRosIp" Width="110" Text="10.98.106.246" />
          <Button Name="btnConnectRos" Width="70" Margin="8,0,0,0" Click="BtnConnectRos_Click">Connect</Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
          <Button Name="btnStart" Width="100" Margin="0,0,8,0" Click="BtnStart_Click">Start Recording</Button>
          <Button Name="btnStop" Width="100" Click="BtnStop_Click">Stop</Button>
        </StackPanel>

        <Button Name="btnCalibrate" Width="260" Margin="0,0,0,8" Click="BtnCalibrate_Click">Calibrate (target origin)</Button>
        
        <TextBlock Name="txtXYZ" Text="X: -, Y: -, Z: -" Margin="0,0,0,8" FontWeight="Bold"/>

        <StackPanel Orientation="Vertical" Margin="0,6,0,0">
          <TextBlock Name="lblKinect" Text="Kinect: Unknown" />
          <TextBlock Name="lblBody" Text="Body: Not tracked" />
          <TextBlock Name="lblRecording" Text="Recording: Inactive" />
        </StackPanel>
        
        <TextBlock FontWeight="Bold" Margin="0,10,0,4">Recording Path</TextBlock>
        <TextBlock Name="txtSavePath" Text="-" TextWrapping="Wrap" FontSize="10" Foreground="Gray"/>
      </StackPanel>

      <!-- New Trajectory Dashboard -->
      <Border Grid.Column="2" Background="#181825" BorderBrush="#45475a" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="10">
            <TextBlock FontSize="16" FontWeight="Bold" Foreground="#89b4fa" Margin="0,0,0,10">Trajectory Dashboard</TextBlock>

            <GroupBox Header="Model Selection" Foreground="#cdd6f4" Margin="0,0,0,10">
               <StackPanel Margin="5">
                  <RadioButton Name="rbGru" Content="GRU (Default)" IsChecked="True" Checked="Model_Checked" Foreground="White" Margin="0,2"/>
                  <RadioButton Name="rbRnn" Content="Simple RNN" Checked="Model_Checked" Foreground="White" Margin="0,2"/>
                  <RadioButton Name="rbLstm" Content="LSTM" Checked="Model_Checked" Foreground="White" Margin="0,2"/>
               </StackPanel>
            </GroupBox>

            <local:TrajectoryPlot x:Name="plotX" Title="X-Axis Trajectory" Margin="0,0,0,5"/>
            <local:TrajectoryPlot x:Name="plotY" Title="Y-Axis Trajectory" Margin="0,0,0,5"/>
            <local:TrajectoryPlot x:Name="plotZ" Title="Z-Axis Trajectory" Margin="0,0,0,10"/>

            <GroupBox Header="System Status" Foreground="#cdd6f4" Margin="0,0,0,10">
               <StackPanel Margin="5">
                  <TextBlock Name="lblActiveModel" Text="Model: GRU" Foreground="#a6e3a1"/>
                  <TextBlock Name="lblBufferStatus" Text="Buffer: 0/20" Foreground="#fab387"/>
                  <TextBlock Name="lblInferenceTime" Text="Inference: 0.0ms" Foreground="#f5e0dc"/>
                  <TextBlock Name="lblBridgeStatus" Text="Bridge: Disconnected" Foreground="#f38ba8"/>
               </StackPanel>
            </GroupBox>
            
            <Button Name="btnResetPlots" Content="Reset Graphs" Click="BtnResetPlots_Click" Margin="0,5,0,0"/>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
      
    <StatusBar Grid.Row="2" HorizontalAlignment="Stretch" Name="statusBar" VerticalAlignment="Bottom" Background="White" Foreground="{StaticResource MediumGreyBrush}">
      <StatusBarItem Content="Ready" />
    </StatusBar>
  </Grid>
</Window>
