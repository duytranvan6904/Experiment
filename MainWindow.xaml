<Window x:Class="Microsoft.Samples.Kinect.BodyBasics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Body Basics" 
        Height="600" Width="900" 
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"> 
  <Window.Resources>
    <SolidColorBrush x:Key="MediumGreyBrush" Color="#ff6e6e6e" />
    <SolidColorBrush x:Key="KinectPurpleBrush" Color="#ff52318f" />
    <SolidColorBrush x:Key="KinectBlueBrush" Color="#ff00BCF2" />
  </Window.Resources>
  <Grid Margin="10 0 10 0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Image Grid.Row="0" Source="Images\Logo.png" HorizontalAlignment="Left" Stretch="Fill" Height="32" Width="81" Margin="0 10 0 5" />
    <TextBlock Grid.Row="0" Margin="0 0 -1 0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{StaticResource MediumGreyBrush}" FontFamily="Segoe UI" FontSize="18">Body Basics</TextBlock>
    <Image Grid.Row="0" Source="Images\Status.png" Stretch="None" HorizontalAlignment="Center" Margin="0 0 0 5" />

    <!-- Main content: image view on the left and control panel on the right -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="320" />
      </Grid.ColumnDefinitions>

      <Viewbox Grid.Column="0" HorizontalAlignment="Center">
        <Image Source="{Binding ImageSource}" Stretch="UniformToFill" />
      </Viewbox>

      <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Top">
        <TextBlock FontSize="16" FontWeight="Bold" Margin="0 0 0 8">Experiment Controls</TextBlock>

        <!-- New ROS TCP Connection controls -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
          <TextBlock VerticalAlignment="Center" Margin="0 0 6 0">ROS IP:</TextBlock>
          <TextBox Name="txtRosIp" Width="110" Text="10.98.106.246" />
          <Button Name="btnConnectRos" Width="70" Margin="8 0 0 0" Click="BtnConnectRos_Click">Connect</Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
          <Button Name="btnStart" Width="100" Margin="0 0 8 0" Click="BtnStart_Click">Start Recording</Button>
          <Button Name="btnStop" Width="100" Click="BtnStop_Click">Stop</Button>
        </StackPanel>

        <Button Name="btnCalibrate" Width="260" Margin="0 0 0 8" Click="BtnCalibrate_Click">Calibrate (set target origin)</Button>

        <!-- New dual-camera calibration controls -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
          <Button Name="btnCalCam1" Width="120" Margin="0 0 8 0" Click="BtnCalibrateCam1_Click">Calibrate Cam1</Button>
          <Button Name="btnCalCam2" Width="120" Click="BtnCalibrateCam2_Click">Calibrate Cam2</Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
          <TextBlock Name="lblCam1Status" Text="Cam1 calibrated: ✘" Width="140" />
          <TextBlock Name="lblCam2Status" Text="Cam2 calibrated: ✘" Width="140" />
        </StackPanel>

        <TextBlock FontSize="14" FontWeight="Bold" Margin="0 8 0 4">Live Hand (world)</TextBlock>
        <TextBlock Name="txtXYZ" Text="X: -, Y: -, Z: -" Margin="0 0 0 8" />
        <!-- New per-camera live displays -->
        <TextBlock Name="txtXYZCam1" Text="Cam1: X: -, Y: -, Z: -" Margin="0 0 0 4" />
        <TextBlock Name="txtXYZCam2" Text="Cam2: X: -, Y: -, Z: -" Margin="0 0 0 8" />

        <StackPanel Orientation="Vertical" Margin="0 6 0 0">
          <TextBlock Name="lblKinect" Text="Kinect: Unknown" />
          <TextBlock Name="lblBody" Text="Body: Not tracked" />
          <TextBlock Name="lblRecording" Text="Recording: Inactive" />
        </StackPanel>

        <StackPanel Orientation="Vertical" Margin="0 8 0 0">
          <TextBlock FontWeight="Bold">Recording Limits</TextBlock>
          <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
            <TextBlock VerticalAlignment="Center" Margin="0 0 6 0">Max Frames:</TextBlock>
            <TextBox Name="txtMaxFrames" Width="100" Text="0" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
            <TextBlock VerticalAlignment="Center" Margin="0 0 6 0">Max Time (s):</TextBlock>
            <TextBox Name="txtMaxTime" Width="100" Text="0" />
          </StackPanel>

          <TextBlock Name="txtCountdown" FontSize="14" FontWeight="Bold" Margin="0 8 0 0">Countdown: -</TextBlock>
          <TextBlock Name="txtSavePath" Text="Save path: -" TextWrapping="Wrap" Width="260" Margin="0 6 0 0" />
        </StackPanel>

      </StackPanel>
    </Grid>
      
    <StatusBar Grid.Row="2" HorizontalAlignment="Stretch" Name="statusBar" VerticalAlignment="Bottom" Background="White" Foreground="{StaticResource MediumGreyBrush}">
      <StatusBarItem Content="Ready" />
    </StatusBar>
  </Grid>
</Window>
